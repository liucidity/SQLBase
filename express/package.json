    "chalk": "^4.1.2",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "pg": "^8.8.0",
    "pg-native": "^3.0.1"
  },
  "devDependencies": {
    "dotenv": "^16.0.3",
    "jest": "^30.3.0",
    "nodemon": "^2.0.20",
    "supertest": "^7.2.2"
  }
