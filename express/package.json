{
  "name": "express",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --exec npm start",
    "db:migrate": "node ./db/migrate.js",
    "db:reset": "node ./db/reset.js",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
